def is_debugger_ready(timeout_sec: float = 1.0) -> bool:
    try:
        with urllib.request.urlopen(DEBUGGER_URL, timeout=timeout_sec) as resp:
            return resp.status == 200
    except (urllib.error.URLError, TimeoutError, OSError):
        return False


def launch_windows_chrome() -> subprocess.Popen[str]:
    cmd = [
        WINDOWS_CHROME,
        f"--remote-debugging-port={PORT}",
        f"--user-data-dir={WINDOWS_PROFILE}",
    ]
    # stdout/stderr を捨て，WSL 側の端末をあまり汚さない
    return subprocess.Popen(
        cmd,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def wait_for_debugger(max_wait_sec: float = 10.0, interval_sec: float = 0.5) -> bool:
    deadline = time.time() + max_wait_sec
    while time.time() < deadline:
        if is_debugger_ready():
            return True
        time.sleep(interval_sec)
    return False


def attach_driver() -> webdriver.Chrome:
    if not is_debugger_ready():
        raise RuntimeError(f'debugger is not ready: {DEBUGGER_URL}')

    opts = Options()
    opts.debugger_address = DEBUGGER_ADDRESS

    service = Service(CHROMEDRIVER)
    d = webdriver.Chrome(service=service, options=opts)
    return d

def get_driver_with_auto_launch() -> webdriver.Chrome:
    try:
        return attach_driver()
    except (WebDriverException, RuntimeError) as e1:
        print("最初の attach に失敗しました。Chrome for Testing を起動して再試行します。")
        print(f"  reason: {e1}")

    proc = launch_windows_chrome()

    if not wait_for_debugger():
        raise RuntimeError(
            "Chrome for Testing を起動しましたが，"
            f"{DEBUGGER_URL} が応答しませんでした。"
        )

    try:
        return attach_driver()
    except WebDriverException as e2:
        # 起動した Chrome をこのスクリプトで残したくないなら terminate を試みる
        if proc.poll() is None:
            try:
                proc.terminate()
            except OSError:
                pass
        raise RuntimeError(
            "Chrome 起動後の attach にも失敗しました。"
        ) from e2


def fetch_in_temporary_tab(driver: webdriver.Chrome, url: str, wait_sec: float = 10.0) -> str:
    # いま見ているタブを覚えておく
    original_handle = driver.current_window_handle

    # 新しいタブを開いて，そこへ切り替える
    driver.switch_to.new_window(WindowTypes.TAB)
    new_handle = driver.current_window_handle

    try:
        driver.get(url)

        # とりあえず「読み込み完了」まで待つ例
        WebDriverWait(driver, wait_sec).until(
            lambda d: d.execute_script("return document.readyState") == "complete"
        )

        # 必要な情報を取得
        html = driver.page_source
        return html

    finally:
        # 一時タブだけ閉じる
        driver.close()

        # 元のタブへ戻る
        driver.switch_to.window(original_handle)

def doQuest(driver: webdriver.Chrome, qid: str, url: str) -> None:
    if not os.path.exists(qid):
        os.mkdir(qid)
    p = f'{qid}/q.html'
    page = fetch_in_temporary_tab(driver, url)
    with open(p, 'w', encoding='UTF-8') as wfp:
        print(page, end='', file=wfp)
    with open(p, 'r', encoding='UTF-8') as fp:
        page = fp.read()
        # It may seem that in the case of
        # "not (fKeep and os.apth.exists(p)" you do not need to read again,
        # but this code forces translation from \r\n to \n.
    samples = extract_codeforces_samples(page)
    print(samples)

    makeMakefile(f'{qid}/Makefile')
    makeSource(f'{qid}/cans.cc')

def problem_name_in_url(url: string) -> string:
    if not (mo := re.search(r'/([^/]+)$', url)):
        die(f'Unknown URL format: {url}')
    return mo[1]

