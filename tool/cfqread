def doQuest(driver: webdriver.Chrome, qid: str, url: str) -> None:
    if not os.path.exists(qid):
        os.mkdir(qid)
    p = f'{qid}/q.html'
    page = fetch_a_page(driver, url)
    with open(p, 'w', encoding='UTF-8') as wfp:
        print(page, end='', file=wfp)
    with open(p, 'r', encoding='UTF-8') as fp:
        page = fp.read()
        # It may seem that in the case of
        # "not (fKeep and os.apth.exists(p)" you do not need to read again,
        # but this code forces translation from \r\n to \n.
    samples = extract_codeforces_samples(page)
    # debug(samples)

    def qprint(zid: str, item: Sample | SplitCase) -> None:
        def sub(tp: str, cont: str) -> None:
            with open(f'{qid}/{tp}_{zid}.txt', 'w', encoding='UTF-8') as wfp:
                print(cont, end='', file=wfp)
        sub('din',  item.input_text)
        sub('dexp', item.output_text)

    for [sno, item] in enumerate(samples, start=1):
        qprint(str(sno), item)
        if (sc := item.split_cases):
            for [cno, citem] in enumerate(sc, start=0):
                qprint(str(sno) + chr(ord('a') + cno), citem)

    shutil.copyfile(f'{getTopDir()}/zCodeForces/Makefile', f'{qid}/Makefile')
    shutil.copyfile(f'{getTopDir()}/zCodeForces/cans.cc', f'{qid}/cans.cc')

def problem_name_in_url(url: string) -> string:
    if not (mo := re.search(r'/([^/]+)$', url)):
        die(f'Unknown URL format: {url}')
    return mo[1]

