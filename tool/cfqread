def doQuest(qid: str, url: str) -> None:
    # debug(f'---------------- doQuest, {qid=}, {url=} ----------------')
    qid = qid.lower()
    warn('Processing', qid, end='... ')
    if not os.path.exists(qid):
        os.mkdir(qid)
    p = f'{qid}/q.html'
    page = fetch_a_page(url)
    with open(p, 'w', encoding='UTF-8') as wfp:
        print(page, end='', file=wfp)
    with open(p, 'r', encoding='UTF-8') as fp:
        page = fp.read()
        # It may seem that in the case of
        # "not (fKeep and os.apth.exists(p)" you do not need to read again,
        # but this code forces translation from \r\n to \n.
    samples = extract_codeforces_samples(page)
    # debug(samples)

    def qprint(zid: str, item: Sample | SplitCase) -> None:
        def sub(tp: str, cont: str) -> None:
            with open(f'{qid}/{tp}_{zid}.txt', 'w', encoding='UTF-8') as wfp:
                print(cont, end='', file=wfp)
        sub('din',  item.input_text)
        sub('dexp', item.output_text)

    for [sno, item] in enumerate(samples, start=1):
        qprint(str(sno), item)
        if (sc := item.split_cases):
            for [cno, citem] in enumerate(sc, start=0):
                qprint(str(sno) + chr(ord('a') + cno), citem)

    shutil.copyfile(f'{getTopDir()}/zCodeForces/Makefile', f'{qid}/Makefile')
    shutil.copyfile(f'{getTopDir()}/zCodeForces/cans.cc', f'{qid}/cans.cc')

def problem_name_in_url(url: str) -> str:
    if not (mo := re.search(r'/([^/]+)$', url)):
        die(f'Unknown URL format: {url}')
    return mo[1].lower()

def get_contest_name(cname: str | None) -> str:
    cn_file = ".contestName"
    if cname:
        with open(cn_file, 'w') as wfp:
            print(cname, file=wfp)
        return cname
    if os.path.exists(cn_file):
        with open(cn_file, 'r') as fp:
            return fp.readline().strip()
    dname = os.path.basename(os.getcwd())
    if (mo := re.match(r'c(\d+)$', dname)):
        return mo[1]
    die('Failed to determine the contest name.')

def get_qdict() -> dict[str, str]:
    if args().url:
        return {problem_name_in_url(args().url): args().url}
    ret : dict[str, str] = {}
    qids : list[str] = []
    contname = get_contest_name(args().contest)
    contest_url = f'https://codeforces.com/contest/{contname}'
    if args().quest:
        qids = args().quest
    elif args().all_questions:
        page_content = fetch_a_page(contest_url)
        with open('qlist.html', 'w') as wfp:
            print(page_content, file=wfp)
        qids = extract_codeforces_contest_problems(page_content).problem_ids
    for qid in qids:
        ret[qid.lower()] = f'{contest_url}/problem/{qid.upper()}'
    return ret

def main() -> None:
    global _args
    _args = parseArgs()

    if args().all_questions and args().quest:
        die('When -a is specified, question ids should not be given.')

    set_driver_with_auto_launch()

    qdict = get_qdict()
    for q in qdict:
        if os.path.exists(q):
            die(f'File or directory {q} exists.')

    try:
        if qdict:
            for q in qdict:
                doQuest(q, qdict[q])

    finally:
        driver().quit()


def parseArgs() -> Namespace:
    parser = ArgumentParser(
        formatter_class=RawDescriptionHelpFormatter,
        description='''
Reads Codeforces questions, extracts input/output examples, makes a makefile 
and cans.cc.  A directory for each problem is created and files are placed into it.
This command uses a Chrome browser under control of selenium.


Examples:
  * cfqread
      Just invokes a browser for later uses, if it is not running.
  * cfqread --url=https://codeforces.com/contest/2208/problem/A
      Reads a single question into the current directory.
  * cfqread --contest 2215 a b1 b2 c
      Reads questions a, b1, b2 and c of Contest 2215.
  * cfqread d e
      Reads questions d and e.  If qread has been executed in this directory,
      the same contest is used.  Otherwise, the name of the current directory
      is assumed as the contest name.
  * cfqread --all_questions
      Reads all questions of the contest.
'''
    )
    parser.add_argument(
        '--url', type=str,
        help='''Problem URL.  If specified, --all_questions, --contest 
        and quest are ignored.
        The question identifier is taken from the last part of the URL.
        ''')
    parser.add_argument(
        '-c', '--contest', type=str,
        help='''Contest identifier, such as 2226.
        If not specified, it is taken from the most recently specified name,
        which has been saved into ./.contestName, or the directory name.
        ''')
    parser.add_argument(
        '-a', '--all_questions', action='store_true',
        help='All questions will be retrieved.')
    parser.add_argument(
        'quest', type=str, nargs='*',
        help='question identifier such as a or f')

    # Without the following code, "-contest" would mistakingly be treated as
    # "-c ontest" ("ontest" is the argument for "-c").
    for arg in sys.argv[1:]:
        if arg.startswith('-') and not arg.startswith('--') and len(arg) > 2:
            parser.error(f'invalid option spelling: {arg!r} '
                         f'(Did you mean "--{arg[1:]}"?)')    

    return parser.parse_args()

if __name__ == "__main__":
    main()



