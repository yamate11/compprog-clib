def is_debugger_ready(timeout_sec: float = 1.0) -> bool:
    try:
        with urllib.request.urlopen(DEBUGGER_URL, timeout=timeout_sec) as resp:
            return resp.status == 200
    except (urllib.error.URLError, TimeoutError, OSError):
        return False


def launch_windows_chrome() -> subprocess.Popen[bytes]:
    cmd = [
        WINDOWS_CHROME,
        f"--remote-debugging-port={PORT}",
        f"--user-data-dir={WINDOWS_PROFILE}",
        '--disable-background-timer-throttling',    # 最小化時にJavaScript実行速度の抑制をしない
    ]
    # stdout/stderr を捨て，WSL 側の端末をあまり汚さない
    return subprocess.Popen(
        cmd,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def wait_for_debugger(max_wait_sec: float = 10.0, interval_sec: float = 0.5) -> bool:
    deadline = time.time() + max_wait_sec
    while time.time() < deadline:
        if is_debugger_ready():
            return True
        time.sleep(interval_sec)
    return False


def attach_driver() -> None:
    global _driver
    if not is_debugger_ready():
        raise RuntimeError(f'debugger is not ready: {DEBUGGER_URL}')

    opts = Options()
    opts.debugger_address = DEBUGGER_ADDRESS

    service = Service(CHROMEDRIVER)
    _driver = webdriver.Chrome(service=service, options=opts)

def set_driver_with_auto_launch() -> None:
    try:
        attach_driver()
        return
    except (WebDriverException, RuntimeError) as e1:
        print("最初の attach に失敗しました。Chrome for Testing を起動して再試行します。")
        print(f"  reason: {e1}")

    proc = launch_windows_chrome()

    if not wait_for_debugger():
        raise RuntimeError(
            "Chrome for Testing を起動しましたが，"
            f"{DEBUGGER_URL} が応答しませんでした。"
        )

    try:
        attach_driver()
        return
    except WebDriverException as e2:
        # 起動した Chrome をこのスクリプトで残したくないなら terminate を試みる
        if proc.poll() is None:
            try:
                proc.terminate()
            except OSError:
                pass
        raise RuntimeError(
            "Chrome 起動後の attach にも失敗しました。"
        ) from e2

def wait_until_page_source_stabilizes(wait_sec: float = 10.0,
                                      interval_sec: float = 0.3,
                                      stable_count_needed: int = 4) -> None:
    """
    page_source の長さが何回か連続で変化しなくなるまで待つ。
    JS で後から DOM が増えるページ向けの雑だが実用的な待ち。
    """
    deadline = time.time() + wait_sec
    prev_len = -1
    stable_count = 0

    while time.time() < deadline:
        cur_len = len(driver().page_source)
        # debug(f'--- cur_len = {cur_len}, stable_count = {stable_count} ------------------------')
        if cur_len == prev_len:
            stable_count += 1
            if stable_count >= stable_count_needed:
                return
        else:
            stable_count = 0
            prev_len = cur_len
        time.sleep(interval_sec)

    raise TimeoutException("page_source が安定しませんでした")

