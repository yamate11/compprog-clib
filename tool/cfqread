    qdict = {}
    if args.url:
        qdict = {problem_name_in_url(args.url): args.url}
    for q in qdict:
        if os.path.exists(q):
            die(f'File or directory {q} exists.')

    driver = get_driver_with_auto_launch()
    try:
        # url = "https://codeforces.com/problemset/problem/4/A"
        # html = fetch_in_temporary_tab(driver, url)
        # print(f'length is {len(html)}')
        if qdict:
            for q in qdict:
                warn('Processing', q, end='... ')
                doQuest(driver, q, qdict[q])
                warn('Done.')

    finally:
        driver.quit()


